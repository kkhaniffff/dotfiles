#!/bin/sh

# Volume
vol_line=$(wpctl get-volume @DEFAULT_AUDIO_SINK@)
vol_val=$(echo "$vol_line" | awk '{printf "%d\n", $2 * 100}')
if echo "$vol_line" | grep -q "MUTED"; then
    vol_icon="¾░¢ü"
elif [ "$vol_val" -ge 50 ]; then
    vol_icon="¾░ĢŠ"
else
    vol_icon="¾░¢Ć"
fi
volume="$vol_icon $vol_val%"
 
# Keyboard Layout
layout=$(swaymsg -t get_inputs \
    | grep -m1 "xkb_active_layout_name" \
    | sed 's/.*: "//;s/",.*//'
)
case "$layout" in
    *English*) layout="us" ;;
    *Russian*) layout="ru" ;;
esac
keyboard="¾░īī $layout"
 
# Network
eth=$(nmcli -t dev status 2>/dev/null | grep ":ethernet:connected:" | cut -d: -f4)
wifi=$(nmcli -t dev status 2>/dev/null | grep ":wifi:connected:" | cut -d: -f4)
 
if [ -n "$eth" ]; then
    network="¾░łĆ $eth"
elif [ -n "$wifi" ]; then
    network="¾░¢® $wifi"
else
    network="¾░¢¬ Disconnected"
fi
 
# Clock
clock="$(date '+¾░āŁ %a %d %b ¾░źö %H:%M')"
 
# Combine
echo "$volume | $keyboard | $network | $clock "
